<Window x:Class="NysLottery.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NYS Lottery Native"
        Height="720"
        Width="1024"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Game:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold" />
            <ComboBox x:Name="GameComboBox" Width="240" Margin="0,0,16,0" DisplayMemberPath="Name" />

            <TextBlock Text="Picks:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold" />
            <TextBox x:Name="PickCountTextBox" Width="80" Text="5" Margin="0,0,16,0" />

            <Button Content="Generate" Width="120" Click="Generate_Click" Margin="0,0,8,0" />
            <Button Content="Check Updates" Width="120" Click="CheckUpdates_Click" />
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="1" Text="Ready." Margin="0,0,0,12" Foreground="#555" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Generated Picks" Margin="0,0,12,0">
                <ListBox x:Name="ResultsListBox" />
            </GroupBox>

            <GroupBox Header="History" Grid.Column="1">
                <TextBox x:Name="HistoryTextBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
